---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Lightbox from "../../components/Lightbox.astro";
import "../../styles/global.css";
---

<BaseLayout
  title="mozaic | Aleksander Płomiński"
  description="mozaic: TUI-based IRC client written in Rust"
  canonical="https://aplominski.dev/projects/mozaic"
>
  <main class="mx-auto max-w-5xl px-6 pb-20 pt-10 md:px-10 md:pt-16">
    <header class="hero reveal">
      <p class="eyebrow">aplominski.dev / projects / mozaic</p>
      <h1 class="hero-title">mozaic</h1>
      <p class="hero-subtitle fade-in" style="--fade-delay: 160ms;">
        TUI-based IRC client written in Rust with full CLI support and minimal footprint.
      </p>
    </header>

    <section class="section reveal" style="--delay: 220ms;">
      <h2>About</h2>
      <p>
        A lightweight terminal-based IRC client built with Rust and Ratatui. Features full IRC protocol
        support including SSL/TLS connections and multi-server support.
        The clean TUI interface provides an efficient IRC experience while maintaining a tiny binary size
        and minimal memory footprint suitable for servers and low-resource environments.
      </p>
    </section>

    <section class="section reveal" style="--delay: 320ms;">
      <h2>Screenshots</h2>
      <div class="gallery">
        <div class="gallery-main">
          <img class="lightbox-trigger gallery-load" loading="lazy" src="/ss/mozaic_main.png" alt="mozaic main interface" />
        </div>
        <div class="gallery-thumbs">
          <img class="lightbox-trigger gallery-load" loading="lazy" style="--fade-delay: 100ms" src="/ss/mozaic_help.png" alt="mozaic help" />
          <img class="lightbox-trigger gallery-load" loading="lazy" style="--fade-delay: 200ms" src="/ss/mozaic_connection.png" alt="mozaic connection" />
        </div>
      </div>
    </section>

    <section class="section reveal" style="--delay: 420ms;">
      <h2>Tech Stack</h2>
      <div class="tech-tags">
        <span>Rust</span>
        <span>Ratatui</span>
        <span>IRC</span>
        <span>TUI</span>
      </div>
    </section>

    <section class="section reveal" style="--delay: 480ms;">
      <h2>Repository</h2>
      <p><a href="https://github.com/aplominski/mozaic" rel="noreferrer">github.com/aplominski/mozaic</a></p>
    </section>

    <div class="mt-10 flex flex-wrap gap-4 fade-in" style="--fade-delay: 520ms;">
      <a class="btn-secondary" href="/projects">&larr; All Projects</a>
      <a class="btn-primary" href="/contact">Contact me</a>
    </div>
  </main>

  <Lightbox />
</BaseLayout>
