---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Lightbox from "../../components/Lightbox.astro";
import "../../styles/global.css";
---

<BaseLayout
  title="OpenDevNote | Aleksander Płomiński"
  description="OpenDevNote: Flutter productivity application"
  canonical="https://aplominski.dev/projects/opendevnote"
>
  <main class="mx-auto max-w-5xl px-6 pb-20 pt-10 md:px-10 md:pt-16">
    <header class="hero reveal">
      <p class="eyebrow">aplominski.dev / projects / opendevnote</p>
      <h1 class="hero-title">OpenDevNote</h1>
      <p class="hero-subtitle fade-in" style="--fade-delay: 160ms;">
        Flutter-based productivity application with calculator, GitHub integration, calendar, and markdown editor.
      </p>
    </header>

    <section class="section reveal" style="--delay: 220ms;">
      <h2>About</h2>
      <p>
        A comprehensive productivity suite built with Flutter for cross-platform deployment. Features an
        integrated scientific calculator with history, GitHub integration with repository overview, commit history,
        and GitHub Actions workflow runs. Issues and pull requests support coming in the next major update.
        Also includes a calendar view and a full-featured markdown editor with live preview and export capabilities.
      </p>
    </section>

    <section class="section reveal" style="--delay: 320ms;">
      <h2>Screenshots</h2>
      <div class="gallery">
        <div class="gallery-main">
          <img class="lightbox-trigger gallery-load" loading="lazy" src="/ss/odn_today.png" alt="opendevnote today view" />
        </div>
        <div class="gallery-thumbs">
          <img class="lightbox-trigger gallery-load" loading="lazy" style="--fade-delay: 100ms" src="/ss/odn_project.png" alt="opendevnote projects" />
          <img class="lightbox-trigger gallery-load" loading="lazy" style="--fade-delay: 200ms" src="/ss/odn_project_view.png" alt="opendevnote project detail" />
        </div>
      </div>
    </section>

    <section class="section reveal" style="--delay: 420ms;">
      <h2>Tech Stack</h2>
      <div class="tech-tags">
        <span>Dart</span>
        <span>Flutter</span>
        <span>GitHub API</span>
        <span>Cross-Platform</span>
      </div>
    </section>

    <section class="section reveal" style="--delay: 480ms;">
      <h2>Repository</h2>
      <p><a href="https://github.com/aplominski/opendevnote" rel="noreferrer">github.com/aplominski/opendevnote</a></p>
    </section>

    <div class="mt-10 flex flex-wrap gap-4 fade-in" style="--fade-delay: 520ms;">
      <a class="btn-secondary" href="/projects">&larr; All Projects</a>
      <a class="btn-primary" href="/contact">Contact me</a>
    </div>
  </main>

  <Lightbox />
</BaseLayout>
