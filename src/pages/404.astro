---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";
---

<BaseLayout
  title="404 | Aleksander Płomiński"
  description="Page not found"
  canonical="https://aplominski.dev/404"
>
  <main class="mx-auto max-w-4xl px-6 pb-20 pt-10 md:px-10 md:pt-16">
    <header class="hero reveal">
      <p class="eyebrow">aplominski.dev / 404</p>
      <h1 class="hero-title">Page Not Found</h1>
      <p class="hero-subtitle fade-in" style="--fade-delay: 160ms;">
        This page doesn't exist - or it used to.
      </p>
    </header>

    <section class="section reveal" style="--delay: 220ms;">
      <div class="flex flex-wrap gap-4">
        <a class="btn-primary" href="/">Go home</a>
        <a class="btn-secondary" href="/projects">View projects</a>
      </div>
    </section>
  </main>
</BaseLayout>
