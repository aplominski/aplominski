---
import "../styles/global.css";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content="Contact Aleksander Płomiński" />
		<link rel="canonical" href="https://aplominski.dev/contact" />
		<title>Contact | Aleksander Płomiński</title>
	</head>
	<body class="bg-graphite text-zinc-100 antialiased">
		<div class="bg-orb bg-orb-a" aria-hidden="true"></div>
		<div class="bg-orb bg-orb-b" aria-hidden="true"></div>

		<main class="mx-auto max-w-4xl px-6 pb-20 pt-10 md:px-10 md:pt-16">
			<header class="hero reveal">
				<p class="eyebrow">aplominski.dev / contact</p>
				<h1 class="hero-title">Let's Talk</h1>
				<p class="hero-subtitle fade-in" style="--fade-delay: 160ms;">
					Open to engineering collaboration, performance work, and systems-focused projects.
				</p>
			</header>

			<section class="section reveal" style="--delay: 220ms;">
				<h2>Contact</h2>
				<div class="highlights">
					<article>
						<h3>Email</h3>
						<p><a href="mailto:hello@aplominski.dev">hello@aplominski.dev</a></p>
					</article>
					<article>
						<h3>GitHub</h3>
						<p><a href="https://github.com/aplominski" rel="noreferrer">github.com/aplominski</a></p>
					</article>
				</div>
				<div class="mt-8 flex flex-wrap gap-4">
					<a class="btn-secondary" href="/">Back to home</a>
					<a class="btn-secondary" href="/projects">View projects</a>
				</div>
			</section>
		</main>

		<noscript>
			<div class="noscript-banner">
				JavaScript is disabled. This page is fully functional without JavaScript.
			</div>
		</noscript>
	</body>
</html>
