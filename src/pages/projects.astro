---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";
---

<BaseLayout
  title="Projects | Aleksander Płomiński"
  description="Projects by Aleksander Płomiński - C/C++/Rust developer"
  canonical="https://aplominski.dev/projects"
>
  <main class="mx-auto max-w-6xl px-6 pb-20 pt-10 md:px-10 md:pt-16">
    <header class="hero reveal">
      <p class="eyebrow">aplominski.dev / projects</p>
      <h1 class="hero-title">Projects</h1>
      <p class="hero-subtitle fade-in" style="--fade-delay: 150ms;">
        Open-source work and side projects.
      </p>
      <div class="mt-8 flex flex-wrap gap-4 fade-in" style="--fade-delay: 260ms;">
        <a class="btn-secondary" href="/">Back to home</a>
        <a class="btn-secondary" href="/contact">Contact page</a>
        <a class="btn-primary" href="mailto:hello@aplominski.dev">Contact me</a>
      </div>
    </header>

    <section class="section reveal" style="--delay: 220ms;">
      <h2>Projects</h2>
      <div class="project-grid">
        <a href="/projects/hs-http" class="project-card">
          <div class="project-thumb">
            <img src="/ss/hs-http_index.png" alt="hs-http" />
          </div>
          <div class="project-info">
            <h3>hs-http</h3>
            <p>HTTP/1.1 & HTTP/2 server with C/C++ plugin support</p>
          </div>
        </a>
        <a href="/projects/mozaic" class="project-card">
          <div class="project-thumb">
            <img src="/ss/mozaic_main.png" alt="mozaic" />
          </div>
          <div class="project-info">
            <h3>mozaic</h3>
            <p>TUI-based IRC client written in Rust</p>
          </div>
        </a>
        <a href="/projects/opendevnote" class="project-card">
          <div class="project-thumb">
            <img src="/ss/odn_today.png" alt="OpenDevNote" />
          </div>
          <div class="project-info">
            <h3>OpenDevNote</h3>
            <p>Flutter productivity app with calculator, GitHub, calendar</p>
          </div>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
