---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import "../../styles/global.css";

const articles = await getCollection("research");
articles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title="Research | Aleksander Płomiński"
  description="Research articles and technical writing by Aleksander Płomiński"
  canonical="https://aplominski.dev/research"
>
  <main class="mx-auto max-w-4xl px-6 pb-20 pt-10 md:px-10 md:pt-16">
    <header class="hero reveal">
      <p class="eyebrow">aplominski.dev / research</p>
      <h1 class="hero-title">Research</h1>
      <p class="hero-subtitle fade-in" style="--fade-delay: 160ms;">
        Technical articles, experiments, and findings.
      </p>
    </header>

    <section class="section reveal" style="--delay: 220ms;">
      {articles.length === 0 && (
        <p class="text-zinc-500">No articles yet.</p>
      )}
      {articles.map((article, i) => (
        <article class="border-b border-white/10 py-8 first:pt-0">
          <a href={`/research/${article.id}`} class="group block">
            <time class="text-sm text-zinc-500">
              {article.data.date.toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </time>
            <h2 class="mt-1 text-xl font-semibold text-zinc-100 group-hover:text-link transition-colors">
              {article.data.title}
            </h2>
            <p class="mt-2 text-zinc-400 leading-relaxed">
              {article.data.description}
            </p>
            {article.data.tags && (
              <div class="mt-3 flex flex-wrap gap-2">
                {article.data.tags.map((tag) => (
                  <span class="rounded-full border border-steel/25 bg-ink/90 px-3 py-0.5 text-xs text-zinc-300">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </a>
        </article>
      ))}
    </section>

    <div class="mt-8 flex flex-wrap gap-4 fade-in" style="--fade-delay: 260ms;">
      <a class="btn-secondary" href="/">Back to home</a>
    </div>
  </main>
</BaseLayout>
